# =================================================================
# 自動車保険見積システム フロントエンド Dockerfile
# =================================================================

# -----------------------------------------------------------------
# 1. ビルドステージ (Build Stage)
# 【設計意図】Node.js環境でReactソースコードをビルド(HTML/CSS/JSの静的生成)し、
# 実行環境にNode.jsコンパイラ自体を持ち込まないことで、コンテナを軽量化する。
# -----------------------------------------------------------------
FROM node:18-alpine AS build
WORKDIR /app

# 【キャッシュ最適化】package.json類を先にコピーしnpm installを実行。
# ソースコードのみが変更された場合、ライブラリのインストールレイヤーをキャッシュから再利用する。
COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

# -----------------------------------------------------------------
# 2. 実行ステージ (Run Stage)
# 【アーキテクチャ設計】ビルドされた静的リソースは、Node.jsでサーブするのではなく、
# メモリフットプリントが非常に小さく静的配信能力に優れたNginxで配信する。
# -----------------------------------------------------------------
FROM nginx:alpine

# ビルドした静的ファイルをNginxのドキュメントルートに配置
COPY --from=build /app/dist /usr/share/nginx/html

# SPA(Single Page Application)ルーティングおよびリバースプロキシ用の設定ファイルを適用
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Web公開用ポートの明示
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]


# =============================================================
# TaSProject 環境変数設定テンプレート
# このファイルをコピーして .env にリネームし、値を設定してください。
# .env は .gitignore により Git管理対象外です（機密情報のため）。
# コピーコマンド: cp .env.example .env
# =============================================================

# ----------------------------------------------------------------
# データベース接続設定 (PostgreSQL)
# Docker Compose 使用時: デフォルト値のまま動作します
# ローカル開発時: ご自身のPostgreSQL接続情報を入力してください
# ----------------------------------------------------------------
DB_USERNAME=quoteuser
DB_PASSWORD=quotepassword

# ローカル開発のみ使用 (docker プロファイルでは不使用)
DB_URL=jdbc:postgresql://localhost:5432/quotesdb

# ----------------------------------------------------------------
# JWT 認証設定
# 本番環境では必ず推測不可能な強固なシークレットに変更してください。
# 生成例: openssl rand -base64 64
# ----------------------------------------------------------------
JWT_SECRET=dGhlLXNlY3JldC1rZXktZm9yLWF1dG9tb2JpbGUtaW5zdXJhbmNlLXF1b3RlLXN5c3RlbS1kZXYtMjAyNjA2Mjk=
JWT_EXPIRATION=86400000

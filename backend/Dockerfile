# =================================================================
# 自動車保険見積システム バックエンド Dockerfile
# =================================================================

# -----------------------------------------------------------------
# 1. ビルドステージ (Build Stage)
# 【設計意図】ビルドツールのMavenおよびJDK環境を実行イメージから分離し、
# 最終的なプロダクションイメージに開発用ライブラリを含めないことで、
# イメージサイズ削減とセキュリティ脆弱性の露出を最小限に抑える。
# -----------------------------------------------------------------
FROM maven:3.9-eclipse-temurin-21-alpine AS build
WORKDIR /app

# 【キャッシュ最適化】pom.xmlのみを先にコピーし依存関係をオフラインダウンロードする。
# これにより、ソースコード(src)の変更時に依存関係の再ダウンロードを回避し、
# Dockerレイヤーキャッシュによるビルド時間短縮を実現する。
COPY pom.xml .
RUN mvn dependency:go-offline

COPY src ./src
RUN mvn clean package -DskipTests

# -----------------------------------------------------------------
# 2. 実行ステージ (Run Stage)
# 【セキュリティ設計】実行環境にはJDKではなく最小限のJRE(Eclipse Temurin)
# かつAlpine Linuxを採用することで、攻撃面(Attack Surface)を極小化する。
# -----------------------------------------------------------------
FROM eclipse-temurin:21-jre-alpine
WORKDIR /app

# ビルドステージからコンパイル済みの最小実行可能なJARのみを抽出
COPY --from=build /app/target/*.jar app.jar

# 内部通信用ポートの明示
EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]

